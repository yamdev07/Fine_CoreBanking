# ─────────────────────────────────────────────────────────────────────────────
# Fine_CoreBanking — Environment Variables
#
# Copy this file to .env and fill in all REQUIRED values before starting.
# NEVER commit .env to version control.
#
# Generate a secure JWT secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECURITY  (REQUIRED — change before any non-local deployment)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Shared HS256 secret — must be identical across accounting & reporting services
JWT_SECRET_KEY=change-me-generate-a-32-byte-hex-secret
JWT_ALGORITHM=HS256
# Token lifetime in minutes (default 60)
JWT_EXPIRE_MINUTES=60

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APPLICATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # Set false in production

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# POSTGRESQL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=accounting_db

# Accounting service (read-write)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/accounting_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Reporting service (read-only replica or same DB with RO user)
ACCOUNTING_DB_URL=postgresql+asyncpg://reporting_ro:reporting_ro@postgres:5432/accounting_db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REDIS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Accounting service — sessions / rate-limiting cache (DB 0)
REDIS_URL=redis://redis-accounting:6379/0

# Reporting service — report cache (DB 1)
REDIS_REPORTING_URL=redis://redis-accounting:6379/1
CACHE_TTL_SECONDS=300            # Default cache TTL (seconds)
CACHE_TTL_ANNUAL_REPORT=3600     # Annual report cache TTL (seconds)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# KAFKA
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

KAFKA_BOOTSTRAP_SERVERS=kafka:9093
KAFKA_CONSUMER_GROUP=accounting-service

# Topics (accounting service publishes; reporting service consumes)
KAFKA_TOPIC_CREDIT_EVENTS=credit.events
KAFKA_TOPIC_SAVINGS_EVENTS=savings.events
KAFKA_TOPIC_CASH_EVENTS=cash.events
KAFKA_TOPIC_ACCOUNTING_EVENTS=accounting.events

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CORS  (comma-separated origins; in production set to your actual domain)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

CORS_ALLOWED_ORIGINS=http://localhost:3000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# INSTITUTION  (used in report headers and exports)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

INSTITUTION_NAME=Ma Banque / IMF
INSTITUTION_COUNTRY=BJ           # ISO 3166-1 alpha-2 country code
EXPORT_AUTHOR=Système Core Banking

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ACCOUNTING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

DEFAULT_CURRENCY=XOF             # ISO 4217 (XOF = Franc CFA BCEAO)
DEFAULT_DECIMAL_PLACES=0         # XOF has no subunit

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FRONTEND  (Next.js public env vars — exposed to the browser)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NEXT_PUBLIC_ACCOUNTING_URL=http://localhost:8000
NEXT_PUBLIC_REPORTING_URL=http://localhost:8001
