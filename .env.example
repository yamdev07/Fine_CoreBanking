# ─────────────────────────────────────────────────────────────────────────────
# Core Banking — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security (REQUIRED — change before deploying) ────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-32-byte-hex-secret

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=accounting_db

# ── CORS (comma-separated, used by accounting & reporting services) ───────────
# In production set to your actual frontend domain(s)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Institution (reporting service) ──────────────────────────────────────────
INSTITUTION_NAME=Ma Banque / IMF
INSTITUTION_COUNTRY=BJ
