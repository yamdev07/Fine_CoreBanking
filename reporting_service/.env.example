# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=reporting-service
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ─── Base de données (lecture seule sur DB comptabilité) ──────────────────────
ACCOUNTING_DB_URL=postgresql+asyncpg://reporting_ro:reporting_ro@localhost:5432/accounting_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─── Redis (cache rapports) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1
CACHE_TTL_SECONDS=300
CACHE_TTL_ANNUAL_REPORT=3600

# ─── Sécurité ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

# ─── Institution ───────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=XOF
INSTITUTION_NAME=Ma Banque / IMF
INSTITUTION_COUNTRY=BJ
EXPORT_AUTHOR=Système Core Banking
